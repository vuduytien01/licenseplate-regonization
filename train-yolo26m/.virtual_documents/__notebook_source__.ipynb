#LOAD MODELS (ULTRA: TENSORRT + ONNX)
from ultralytics import YOLO
import onnxruntime as ort
import torch
#TENSORRT YOLO
model = YOLO("/kaggle/input/datasets/vdt1501/yolo26m-pt/yolo26m.pt")

model.export(
    format="engine",
    half=True,
    device=0,
    imgsz=640
) 
#OCR ONNX EXPORT
pt = torch.jit.load(
    "/kaggle/input/datasets/vdt1501/parseq-bb5792a6-pt/parseq-bb5792a6.pt"
).cuda().eval()

dummy = torch.randn(1,3,32,128).cuda()

torch.onnx.export(
    pt,
    dummy,
    "parseq.onnx",
    opset_version=17,
    input_names=["img"],
    output_names=["out"],
    dynamic_axes={"img": {0: "batch"}}
)
# ===== PARSeq ONNX =====
ocr_session = ort.InferenceSession(
    "parseq.onnx",
    providers=["CUDAExecutionProvider"]
)


# ===== YOLO TensorRT =====
frame_q = queue.Queue(8)
det_q = queue.Queue(8)
det_model = YOLO("yolo26m.engine") 


#YOLO WORKER(TENSORRT)
def yolo_worker():
    while True:
        item = frame_q.get()
        if item is None:
            det_q.put(None)
            break

        path, img = item
        res = det_model(img)[0]

        boxes = res.boxes.xyxy.cpu().numpy().astype(int) if len(res.boxes) else []
        det_q.put((path, img, boxes))


import numpy as np
#PREPROCESS(FAST CV2)
def preprocess(img, boxes):
    crops = []
    for x1,y1,x2,y2 in boxes:
        c = img[y1:y2, x1:x2]
        c = cv2.resize(c, (128,32))
        crops.append(c)
    return crops
#OCR WORKER (ONNX FASTEST)
def ocr_worker():
    while True:
        item = det_q.get()
        if item is None:
            break

        path, img, boxes = item
        if len(boxes) == 0:
            continue

        crops = preprocess(img, boxes)

        for i in range(0, len(crops), 32):
            batch = crops[i:i+32]

            x = np.stack(batch).astype(np.float32)/255.0
            x = x.transpose(0,3,1,2)

            out = ocr_session.run(None, {"img": x})[0]

            print(path, out)


def loader():
    root = "/kaggle/input"
    for r,_,f in os.walk(root):
        for x in f:
            if x.lower().endswith((".jpg",".png",".jpeg")):
                p = os.path.join(r,x)
                img = cv2.imread(p)
                yield (p,img)


def run():
    t1 = threading.Thread(target=yolo_worker)
    t2 = threading.Thread(target=ocr_worker)

    t1.start()
    t2.start()

    for item in loader():
        frame_q.put(item)

    frame_q.put(None)

    t1.join()
    t2.join()

run()
